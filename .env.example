# Copy to .env and edit. Defaults run keyless via the `test` provider.

# --- LLM: test (default) | openai | anthropic | ollama ---
llm_provider=test
# openai_api_key=sk-...
# anthropic_api_key=sk-ant-...
# ollama_host=http://localhost:11434

# --- paths ---
prompts_dir=./prompts
golden_path=./data/golden.jsonl
db_path=./data/runs.db
report_dir=./reports

# --- alerting (optional) ---
# slack_webhook_url=https://hooks.slack.com/services/XXX/YYY/ZZZ
